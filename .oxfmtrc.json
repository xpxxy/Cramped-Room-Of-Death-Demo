{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "tabWidth": 2,
  "bracketSpacing": true,
  "singleQuote": true,
  "trailingComma": "all",
  "arrowParens": "avoid",
  "endOfLine": "lf",
  "printWidth": 120,
  "requirePragma": false,
  "sortPackageJson": false,
  "ignorePatterns": ["node_modules/", "dist/", "**.meta", "**.png"]
}